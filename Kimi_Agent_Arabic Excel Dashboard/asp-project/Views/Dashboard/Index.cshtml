@model DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
    bool hasData = ViewBag.HasData ?? false;
}

@if (!hasData)
{
    <div class="text-center py-5">
        <div class="mb-4">
            <i class="bi bi-file-earmark-excel display-1 text-muted"></i>
        </div>
        <h2 class="mb-3">لا توجد بيانات</h2>
        <p class="text-muted mb-4">يرجى رفع ملف Excel لعرض الإحصائيات</p>
        <a href="@Url.Action("Upload", "Dashboard")" class="btn btn-primary btn-lg">
            <i class="bi bi-cloud-upload me-2"></i>
            رفع ملف Excel
        </a>
    </div>
}
else
{
    <!-- Filters Section -->
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-funnel me-2"></i>
                عوامل التصفية
            </h5>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" id="filterForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Filters.DateFrom" class="form-label"></label>
                        <input asp-for="Filters.DateFrom" type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.DateTo" class="form-label"></label>
                        <input asp-for="Filters.DateTo" type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.Province" class="form-label"></label>
                        <select asp-for="Filters.Province" class="form-select">
                            <option value="">-- الكل --</option>
                            @foreach (var p in Model.ProvinceOptions)
                            {
                                <option value="@p" selected="@(Model.Filters.Province == p ? "selected" : null)">@p</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.Commune" class="form-label"></label>
                        <select asp-for="Filters.Commune" class="form-select">
                            <option value="">-- الكل --</option>
                            @foreach (var c in Model.CommuneOptions)
                            {
                                <option value="@c" selected="@(Model.Filters.Commune == c ? "selected" : null)">@c</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.Gender" class="form-label"></label>
                        <select asp-for="Filters.Gender" class="form-select">
                            <option value="">-- الكل --</option>
                            @foreach (var g in Model.GenderOptions)
                            {
                                <option value="@g" selected="@(Model.Filters.Gender == g ? "selected" : null)">@g</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.RequestType" class="form-label"></label>
                        <select asp-for="Filters.RequestType" class="form-select">
                            <option value="">-- الكل --</option>
                            @foreach (var t in Model.RequestTypeOptions)
                            {
                                <option value="@t" selected="@(Model.Filters.RequestType == t ? "selected" : null)">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.Status" class="form-label"></label>
                        <select asp-for="Filters.Status" class="form-select">
                            <option value="">-- الكل --</option>
                            @foreach (var s in Model.StatusOptions)
                            {
                                <option value="@s" selected="@(Model.Filters.Status == s ? "selected" : null)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filters.SearchTerm" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Filters.SearchTerm" class="form-control" placeholder="بحث..." />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel me-1"></i> تطبيق
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> إلغاء التصفية
                    </a>
                    <a href="@Url.Action("ExportCsv", new { 
                        Filters.DateFrom, Filters.DateTo, Filters.Province, 
                        Filters.Commune, Filters.Gender, Filters.RequestType, Filters.Status })" 
                       class="btn btn-success">
                        <i class="bi bi-download me-1"></i> تصدير CSV
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card stat-card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">إجمالي التسجيلات</h6>
                            <h3 class="mb-0">@Model.TotalInscriptions.ToString("N0")</h3>
                        </div>
                        <i class="bi bi-people-fill stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">المقبولة</h6>
                            <h3 class="mb-0">@Model.ApprovedCount.ToString("N0")</h3>
                            <small>@Model.ApprovalRate%</small>
                        </div>
                        <i class="bi bi-check-circle-fill stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">المرفوضة</h6>
                            <h3 class="mb-0">@Model.RejectedCount.ToString("N0")</h3>
                        </div>
                        <i class="bi bi-x-circle-fill stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">قيد المعالجة</h6>
                            <h3 class="mb-0">@Model.PendingCount.ToString("N0")</h3>
                        </div>
                        <i class="bi bi-hourglass-split stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 1: Daily Trends & Gender -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>التسجيلات اليومية</h5>
                </div>
                <div class="card-body">
                    <canvas id="dailyTrendsChart" height="100"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>التوزيع حسب الجنس</h5>
                </div>
                <div class="card-body">
                    <canvas id="genderChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 2: Province & Status -->
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>التسجيلات حسب العمالة/الإقليم</h5>
                </div>
                <div class="card-body">
                    <canvas id="provinceChart" height="120"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-flag me-2"></i>الوضعية</h5>
                </div>
                <div class="card-body">
                    <canvas id="statusChart" height="120"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row 3: Request Type, Marital Status, Education -->
    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-file-earmark me-2"></i>نوع الطلب</h5>
                </div>
                <div class="card-body">
                    <canvas id="requestTypeChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-heart me-2"></i>الحالة العائلية</h5>
                </div>
                <div class="card-body">
                    <canvas id="maritalChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-mortarboard me-2"></i>المستوى الدراسي</h5>
                </div>
                <div class="card-body">
                    <canvas id="educationChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Rejection Reasons (if any) -->
    @if (Model.RejectionReasons.Any())
    {
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-x-octagon me-2"></i>أسباب الرفض</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="rejectionChart" height="80"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Data Table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-table me-2"></i>بيانات التسجيلات</h5>
            <span class="badge bg-secondary">@Model.TotalInscriptions.ToString("N0") سجل</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>رقم الطلب</th>
                            <th>التاريخ</th>
                            <th>نوع الطلب</th>
                            <th>الإسم</th>
                            <th>الجنس</th>
                            <th>العمالة/الإقليم</th>
                            <th>الجماعة</th>
                            <th>الوضعية</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Inscriptions.Count; i++)
                        {
                            var item = Model.Inscriptions[i];
                            <tr>
                                <td>@((Model.CurrentPage - 1) * Model.PageSize + i + 1)</td>
                                <td>@item.RequestNumber</td>
                                <td>@(item.RequestDate?.ToString("yyyy/MM/dd") ?? "-")</td>
                                <td>@item.RequestType</td>
                                <td>@item.FullName</td>
                                <td>@item.Gender</td>
                                <td>@item.ResidenceProvince</td>
                                <td>@item.ResidenceCommune</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(item.RequestStatus)">
                                        @item.RequestStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = p, Filters = Model.Filters })">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        // Chart.js default config for RTL
        Chart.defaults.font.family = "'Cairo', sans-serif";
        Chart.defaults.color = '#374151';

        // Color palette
        const colors = {
            primary: ['#3B82F6', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6', '#EC4899', '#06B6D4', '#84CC16'],
            backgrounds: ['rgba(59,130,246,0.7)', 'rgba(16,185,129,0.7)', 'rgba(245,158,11,0.7)', 
                         'rgba(239,68,68,0.7)', 'rgba(139,92,246,0.7)', 'rgba(236,72,153,0.7)',
                         'rgba(6,182,212,0.7)', 'rgba(132,204,22,0.7)']
        };

        // Daily Trends Chart
        const dailyCtx = document.getElementById('dailyTrendsChart').getContext('2d');
        const dailyData = @Html.Raw(Json.Serialize(Model.DailyTrends));
        new Chart(dailyCtx, {
            type: 'line',
            data: {
                labels: dailyData.map(d => d.label),
                datasets: [{
                    label: 'عدد التسجيلات',
                    data: dailyData.map(d => d.value),
                    borderColor: '#3B82F6',
                    backgroundColor: 'rgba(59,130,246,0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 } }
                }
            }
        });

        // Gender Chart
        const genderCtx = document.getElementById('genderChart').getContext('2d');
        const genderData = @Html.Raw(Json.Serialize(Model.GenderBreakdown));
        new Chart(genderCtx, {
            type: 'doughnut',
            data: {
                labels: genderData.map(d => d.label),
                datasets: [{
                    data: genderData.map(d => d.value),
                    backgroundColor: genderData.map(d => d.color || '#3B82F6')
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // Province Chart
        const provCtx = document.getElementById('provinceChart').getContext('2d');
        const provData = @Html.Raw(Json.Serialize(Model.ProvinceBreakdown));
        new Chart(provCtx, {
            type: 'bar',
            data: {
                labels: provData.map(d => d.label),
                datasets: [{
                    label: 'التسجيلات',
                    data: provData.map(d => d.value),
                    backgroundColor: colors.backgrounds
                }]
            },
            options: {
                responsive: true,
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });

        // Status Chart
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        const statusData = @Html.Raw(Json.Serialize(Model.StatusBreakdown));
        new Chart(statusCtx, {
            type: 'bar',
            data: {
                labels: statusData.map(d => d.label),
                datasets: [{
                    label: 'العدد',
                    data: statusData.map(d => d.value),
                    backgroundColor: statusData.map(d => d.color || '#6B7280')
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });

        // Request Type Chart
        const reqCtx = document.getElementById('requestTypeChart').getContext('2d');
        const reqData = @Html.Raw(Json.Serialize(Model.RequestTypeBreakdown));
        new Chart(reqCtx, {
            type: 'pie',
            data: {
                labels: reqData.map(d => d.label),
                datasets: [{
                    data: reqData.map(d => d.value),
                    backgroundColor: colors.backgrounds
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12 } }
                }
            }
        });

        // Marital Status Chart
        const marCtx = document.getElementById('maritalChart').getContext('2d');
        const marData = @Html.Raw(Json.Serialize(Model.MaritalStatusBreakdown));
        new Chart(marCtx, {
            type: 'pie',
            data: {
                labels: marData.map(d => d.label),
                datasets: [{
                    data: marData.map(d => d.value),
                    backgroundColor: colors.backgrounds.slice(2)
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12 } }
                }
            }
        });

        // Education Chart
        const eduCtx = document.getElementById('educationChart').getContext('2d');
        const eduData = @Html.Raw(Json.Serialize(Model.EducationBreakdown));
        new Chart(eduCtx, {
            type: 'doughnut',
            data: {
                labels: eduData.map(d => d.label),
                datasets: [{
                    data: eduData.map(d => d.value),
                    backgroundColor: colors.backgrounds.slice(4)
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12 } }
                }
            }
        });

        // Rejection Reasons Chart
        const rejChart = document.getElementById('rejectionChart');
        if (rejChart) {
            const rejData = @Html.Raw(Json.Serialize(Model.RejectionReasons));
            new Chart(rejChart.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: rejData.map(d => d.label),
                    datasets: [{
                        label: 'العدد',
                        data: rejData.map(d => d.value),
                        backgroundColor: 'rgba(239,68,68,0.7)'
                    }]
                },
                options: {
                    responsive: true,
                    indexAxis: 'y',
                    plugins: { legend: { display: false } },
                    scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });
        }
    </script>
}

@functions {
    string GetStatusBadgeClass(string status)
    {
        if (status.Contains("مقبول")) return "bg-success";
        if (status.Contains("مرفوض")) return "bg-danger";
        if (status.Contains("قيد") || status.Contains("معلق")) return "bg-warning text-dark";
        return "bg-secondary";
    }
}

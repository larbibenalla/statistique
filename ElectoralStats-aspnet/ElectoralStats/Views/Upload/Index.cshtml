@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@{ ViewData["Title"] = L["Upload"].Value; }
<h2>@L["UploadTitle"]</h2>
<p class="text-muted">@L["UploadHint"]</p>
<form id="upForm" enctype="multipart/form-data">
    <input id="files" name="files" type="file" multiple accept=".xlsx,.xls" webkitdirectory="" directory="" class="form-control mb-2"/>
    <input id="filesPlain" name="files" type="file" multiple accept=".xlsx,.xls" class="form-control mb-2"/>
    <button class="btn btn-primary" type="submit">@L["ImportNow"]</button>
</form>
<div id="progress" class="mt-3"></div>
<div id="results" class="mt-3"></div>
<script src="~/js/upload.js"></script>

@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar");
}
<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["AppTitle"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    @if (isRtl)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    }
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
    <div class="container-fluid">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">@L["AppTitle"]</a>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-light btn-sm" asp-controller="Upload" asp-action="Index">@L["Upload"]</a>
            <a class="btn btn-outline-light btn-sm" asp-controller="Stats" asp-action="Index">@L["Stats"]</a>
            <form method="post" asp-controller="Home" asp-action="SetCulture" class="d-flex gap-1">
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                <button name="culture" value="ar-MA" class="btn btn-sm @(culture=="ar-MA"?"btn-light":"btn-outline-light")">العربية</button>
                <button name="culture" value="fr-FR" class="btn btn-sm @(culture=="fr-FR"?"btn-light":"btn-outline-light")">FR</button>
                <button name="culture" value="en-US" class="btn btn-sm @(culture=="en-US"?"btn-light":"btn-outline-light")">EN</button>
            </form>
        </div>
    </div>
</nav>
<main class="container-fluid">
    @RenderBody()
</main>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
